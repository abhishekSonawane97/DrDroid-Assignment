# Supabase (Auth, Postgres, Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google/GitHub OAuth apps (see supabase/config.toml [auth.external.*]).
# Redirect URI to register with each provider:
#   local:      http://127.0.0.1:54321/auth/v1/callback
#   production: https://<project-ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Drizzle — direct Postgres connection string (Supabase project settings > Database)
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Search (platform-owned key)
SERPER_API_KEY=

# Symmetric key used to encrypt user-supplied BYOK API keys at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=

# Used to build absolute URLs (OAuth callbacks, Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
